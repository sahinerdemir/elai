{
  "name": "elai-studio",
  "version": "1.0.0",
  "scripts": {
    "dev": "npx @11ty/eleventy --serve",
    "build": "npx @11ty/eleventy",
    "css:build": "npx tailwindcss -i ./src/assets/css/input.css -o ./dist/assets/css/style.css --minify",
    "css:watch": "npx tailwindcss -i ./src/assets/css/input.css -o ./dist/assets/css/style.css --watch"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "tailwindcss": "^3.4.0",
    "@tailwindcss/typography": "^0.5.0"
  }
}
