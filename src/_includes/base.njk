<!DOCTYPE html>
<html lang="{{ lang }}" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ site.name }} — Creative Studio</title>
  <meta name="description" content="{{ i18n[locale].hero.headline }}">
  <link rel="icon" type="image/svg+xml" href="/assets/logo.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body class="bg-dark text-white overflow-x-hidden">

  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="navbar">
    <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
      <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}" class="flex items-center">
        <img src="/assets/logo.svg" alt="ELAI" class="h-8 invert">
      </a>
      <div class="hidden md:flex items-center gap-10">
        <a href="#about" class="nav-link">{{ i18n[locale].nav.about }}</a>
        <a href="#services" class="nav-link">{{ i18n[locale].nav.services }}</a>
        <a href="#portfolio" class="nav-link">{{ i18n[locale].nav.portfolio }}</a>
        <a href="#contact" class="nav-link">{{ i18n[locale].nav.contact }}</a>
      </div>
      <div class="flex items-center gap-6">
        <div class="lang-switcher flex gap-3">
          <a href="/" class="{{ 'active' if lang == 'en' }}">EN</a>
          <a href="/es/" class="{{ 'active' if lang == 'es' }}">ES</a>
          <a href="/ru/" class="{{ 'active' if lang == 'ru' }}">RU</a>
        </div>
        <a href="#contact" class="btn-primary text-sm hidden md:inline-flex">{{ i18n[locale].contact.cta }}</a>
        <button class="md:hidden text-white" id="menu-toggle" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
    <!-- Mobile menu -->
    <div class="hidden md:hidden bg-dark/95 backdrop-blur-xl border-t border-white/10" id="mobile-menu">
      <div class="px-6 py-8 flex flex-col gap-6">
        <a href="#about" class="nav-link text-lg">{{ i18n[locale].nav.about }}</a>
        <a href="#services" class="nav-link text-lg">{{ i18n[locale].nav.services }}</a>
        <a href="#portfolio" class="nav-link text-lg">{{ i18n[locale].nav.portfolio }}</a>
        <a href="#contact" class="nav-link text-lg">{{ i18n[locale].nav.contact }}</a>
      </div>
    </div>
  </nav>

  <!-- Hero Section with Video Background -->
  <section class="relative h-screen flex items-center justify-center overflow-hidden">
    <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover">
      <source src="/assets/background.mp4" type="video/mp4">
    </video>
    <div class="absolute inset-0 bg-dark/60"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
      <p class="text-accent font-medium tracking-widest uppercase text-sm mb-6 fade-in">Creative Studio</p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold leading-tight mb-8 fade-in" style="animation-delay: 0.2s">
        {{ i18n[locale].hero.headline }}
      </h1>
      <p class="text-xl md:text-2xl text-white/60 font-light mb-10 fade-in" style="animation-delay: 0.4s">{{ i18n[locale].hero.subline }}</p>
      <a href="#portfolio" class="btn-primary text-lg fade-in" style="animation-delay: 0.6s">{{ i18n[locale].hero.cta }}</a>
    </div>
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </div>
  </section>

  <!-- Marquee -->
  <div class="py-6 border-y border-white/10 overflow-hidden">
    <div class="flex whitespace-nowrap marquee">
      {% for i in range(0, 8) %}
      <span class="text-5xl md:text-7xl font-display font-bold text-white/5 mx-8">ELAI STUDIO</span>
      {% endfor %}
    </div>
  </div>

  <!-- About Section -->
  <section id="about" class="py-24 md:py-36">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-accent font-medium tracking-widest uppercase text-sm mb-4">{{ i18n[locale].about.title }}</p>
          <h2 class="section-title mb-8">{{ i18n[locale].about.title }}</h2>
          <p class="text-lg text-white/70 leading-relaxed">{{ i18n[locale].about.text }}</p>
        </div>
        <div class="grid grid-cols-3 gap-6">
          <div class="text-center">
            <div class="text-5xl font-display font-bold text-accent mb-2">5+</div>
            <p class="text-sm text-white/50">{{ i18n[locale].about.experience }}</p>
          </div>
          <div class="text-center">
            <div class="text-5xl font-display font-bold text-accent mb-2">120+</div>
            <p class="text-sm text-white/50">{{ i18n[locale].about.projects }}</p>
          </div>
          <div class="text-center">
            <div class="text-5xl font-display font-bold text-accent mb-2">80+</div>
            <p class="text-sm text-white/50">{{ i18n[locale].about.clients }}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-24 md:py-36 bg-white/[0.02]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-20">
        <p class="text-accent font-medium tracking-widest uppercase text-sm mb-4">{{ i18n[locale].services.subtitle }}</p>
        <h2 class="section-title">{{ i18n[locale].services.title }}</h2>
      </div>
      <div class="space-y-4">
        {% for service in i18n[locale].services.items %}
        <div class="service-card group flex flex-col md:flex-row md:items-center gap-6">
          <div class="flex items-center justify-center w-16 h-16 rounded-full bg-accent/10 text-accent font-display font-bold text-2xl shrink-0">
            0{{ loop.index }}
          </div>
          <div class="flex-1">
            <h3 class="text-2xl md:text-3xl font-display font-semibold mb-2 group-hover:text-accent transition-colors">{{ service.title }}</h3>
            <p class="text-white/50 leading-relaxed">{{ service.desc }}</p>
          </div>
          <svg class="w-8 h-8 text-white/20 group-hover:text-accent group-hover:translate-x-2 transition-all shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Portfolio Section -->
  <section id="portfolio" class="py-24 md:py-36">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16">
        <div>
          <p class="text-accent font-medium tracking-widest uppercase text-sm mb-4">{{ i18n[locale].portfolio.subtitle }}</p>
          <h2 class="section-title">{{ i18n[locale].portfolio.title }}</h2>
        </div>
        <a href="#" class="btn-outline mt-6 md:mt-0">{{ i18n[locale].portfolio.moreWorks }}</a>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {% set projects = [
          { "title": "Brand Identity Project", "cat": "Branding", "year": "2025" },
          { "title": "E-Commerce Platform", "cat": "Web Development", "year": "2025" },
          { "title": "Motion Reel", "cat": "Animation", "year": "2024" },
          { "title": "Corporate Website", "cat": "Web Design", "year": "2024" },
          { "title": "Product Commercial", "cat": "Film", "year": "2025" },
          { "title": "Startup Landing Page", "cat": "Web Development", "year": "2025" }
        ] %}
        {% for project in projects %}
        <div class="portfolio-card group {{ 'md:col-span-2' if loop.index == 1 }}">
          <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/20 to-transparent z-10"></div>
          <div class="absolute inset-0 bg-white/5 flex items-center justify-center">
            <span class="text-white/20 text-lg font-medium">{{ project.cat }} — Placeholder Image</span>
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-8 z-20">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs tracking-widest uppercase text-accent">{{ project.cat }}</span>
              <span class="text-xs text-white/30">{{ project.year }}</span>
            </div>
            <h3 class="text-2xl md:text-3xl font-display font-semibold group-hover:text-accent transition-colors">{{ project.title }}</h3>
          </div>
          <div class="absolute inset-0 z-30 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-dark/60">
            <span class="btn-primary">{{ i18n[locale].portfolio.viewProject }}</span>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Testimonials Marquee -->
  <div class="py-16 border-y border-white/10 overflow-hidden">
    <div class="flex whitespace-nowrap marquee">
      {% for item in i18n[locale].testimonials.items %}
      <span class="text-3xl md:text-5xl font-display font-bold text-white/10 mx-8">★ {{ item }}</span>
      {% endfor %}
      {% for item in i18n[locale].testimonials.items %}
      <span class="text-3xl md:text-5xl font-display font-bold text-white/10 mx-8">★ {{ item }}</span>
      {% endfor %}
    </div>
  </div>

  <!-- Contact Section -->
  <section id="contact" class="py-24 md:py-36">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="text-accent font-medium tracking-widest uppercase text-sm mb-4">{{ i18n[locale].contact.cta }}</p>
      <h2 class="section-title mb-6">{{ i18n[locale].contact.title }}</h2>
      <p class="text-xl text-white/50 mb-12">{{ i18n[locale].contact.subtitle }}</p>
      <form class="max-w-2xl mx-auto space-y-6 text-left">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm text-white/50 mb-2">{{ i18n[locale].contact.nameLabel }}</label>
            <input type="text" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white placeholder-white/30 focus:border-accent focus:outline-none transition-colors" placeholder="{{ i18n[locale].contact.nameLabel }}">
          </div>
          <div>
            <label class="block text-sm text-white/50 mb-2">{{ i18n[locale].contact.emailLabel }}</label>
            <input type="email" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white placeholder-white/30 focus:border-accent focus:outline-none transition-colors" placeholder="{{ i18n[locale].contact.emailLabel }}">
          </div>
        </div>
        <div>
          <label class="block text-sm text-white/50 mb-2">{{ i18n[locale].contact.messageLabel }}</label>
          <textarea rows="5" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white placeholder-white/30 focus:border-accent focus:outline-none transition-colors resize-none" placeholder="{{ i18n[locale].contact.messageLabel }}"></textarea>
        </div>
        <div class="text-center pt-4">
          <button type="submit" class="btn-primary text-lg">{{ i18n[locale].contact.send }}</button>
        </div>
      </form>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-white/10 py-12">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-8">
        <div class="flex items-center gap-6">
          <img src="/assets/logo.svg" alt="ELAI" class="h-6 invert opacity-50">
          <span class="text-sm text-white/30">© 2025 {{ site.name }}. {{ i18n[locale].footer.rights }}</span>
        </div>
        <div class="flex items-center gap-8">
          <a href="#about" class="text-sm text-white/40 hover:text-white transition-colors">{{ i18n[locale].nav.about }}</a>
          <a href="#services" class="text-sm text-white/40 hover:text-white transition-colors">{{ i18n[locale].nav.services }}</a>
          <a href="#portfolio" class="text-sm text-white/40 hover:text-white transition-colors">{{ i18n[locale].nav.portfolio }}</a>
          <a href="#contact" class="text-sm text-white/40 hover:text-white transition-colors">{{ i18n[locale].nav.contact }}</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    // Navbar scroll effect
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar.style.backgroundColor = 'rgba(10,10,10,0.9)';
        navbar.style.backdropFilter = 'blur(24px)';
        navbar.style.paddingTop = '0.5rem';
        navbar.style.paddingBottom = '0.5rem';
      } else {
        navbar.style.backgroundColor = '';
        navbar.style.backdropFilter = '';
        navbar.style.paddingTop = '';
        navbar.style.paddingBottom = '';
      }
    });

    // Mobile menu toggle
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    menuToggle.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    // Close mobile menu on link click
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => mobileMenu.classList.add('hidden'));
    });

    // Scroll animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('fade-in');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.service-card, .portfolio-card, #about, #contact').forEach(el => {
      observer.observe(el);
    });
  </script>
</body>
</html>
