<!DOCTYPE html>
<html lang="{{ lang }}" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ site.name }} — Creative Studio</title>
  <meta name="description" content="{{ i18n[locale].hero.headline }}">
  <link rel="icon" type="image/svg+xml" href="/assets/logo.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body class="bg-dark text-white overflow-x-hidden">

  <!-- Navigation -->
  <nav class="fixed z-50 transition-all duration-300" style="top: 32px; left: 32px; right: 32px; border-radius: 9999px; background: rgba(255,255,255,0.05); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.08);" id="navbar">
    <div class="px-6 py-3 flex items-center justify-between">
      <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}" class="flex items-center">
        <img src="/assets/logo.svg" alt="ELAI" class="invert" style="height: 26px;">
      </a>
      <div class="hidden md:flex items-center gap-10">
        <a href="#about" class="nav-link">{{ i18n[locale].nav.about }}</a>
        <a href="#services" class="nav-link">{{ i18n[locale].nav.services }}</a>
        <a href="#portfolio" class="nav-link">{{ i18n[locale].nav.portfolio }}</a>
        <a href="#pricing" class="nav-link">{{ i18n[locale].nav.pricing }}</a>
        <a href="#contact" class="nav-link">{{ i18n[locale].nav.contact }}</a>
      </div>
      <div class="flex items-center gap-6">
        <div class="lang-switcher flex gap-3">
          <a href="/" class="{{ 'active' if lang == 'en' }}">EN</a>
          <a href="/es/" class="{{ 'active' if lang == 'es' }}">ES</a>
          <a href="/ru/" class="{{ 'active' if lang == 'ru' }}">RU</a>
        </div>
        <a href="#contact" class="btn-primary text-sm hidden md:inline-flex">{{ i18n[locale].contact.cta }}</a>
        <button class="md:hidden text-white" id="menu-toggle" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Fullscreen Mobile Menu -->
  <div class="fixed inset-0 z-[100] hidden md:hidden" id="mobile-menu">
    <div class="absolute inset-0" style="background: rgba(10,10,10,0.85); backdrop-filter: blur(40px); -webkit-backdrop-filter: blur(40px);"></div>
    <div class="relative z-10 flex flex-col h-full px-8 py-10">
      <div class="flex items-center justify-between mb-16">
        <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}" class="flex items-center">
          <img src="/assets/logo.svg" alt="ELAI" class="invert" style="height: 26px;">
        </a>
        <button class="text-white w-10 h-10 flex items-center justify-center" id="menu-close" aria-label="Close">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <nav class="flex flex-col gap-8 flex-1">
        <a href="#about" class="text-4xl font-display font-light text-white/80 hover:text-accent transition-colors">{{ i18n[locale].nav.about }}</a>
        <a href="#services" class="text-4xl font-display font-light text-white/80 hover:text-accent transition-colors">{{ i18n[locale].nav.services }}</a>
        <a href="#portfolio" class="text-4xl font-display font-light text-white/80 hover:text-accent transition-colors">{{ i18n[locale].nav.portfolio }}</a>
        <a href="#pricing" class="text-4xl font-display font-light text-white/80 hover:text-accent transition-colors">{{ i18n[locale].nav.pricing }}</a>
        <a href="#contact" class="text-4xl font-display font-light text-white/80 hover:text-accent transition-colors">{{ i18n[locale].nav.contact }}</a>
      </nav>
      <div class="pt-8 border-t border-white/10">
        <div class="lang-switcher flex gap-4">
          <a href="/" class="text-sm {{ 'active' if lang == 'en' }}">EN</a>
          <a href="/es/" class="text-sm {{ 'active' if lang == 'es' }}">ES</a>
          <a href="/ru/" class="text-sm {{ 'active' if lang == 'ru' }}">RU</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Hero Section with Video Background -->
  <section class="relative h-screen flex items-center justify-center overflow-hidden">
    <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover">
      <source src="/assets/background.mp4" type="video/mp4">
    </video>
    <div class="absolute inset-0 bg-dark/60"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
      <p class="text-accent font-medium tracking-widest uppercase text-sm mb-6 fade-in">Creative Studio</p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold leading-tight mb-8 fade-in" style="animation-delay: 0.2s">
        {{ i18n[locale].hero.headline }}
      </h1>
      <p class="text-xl md:text-2xl text-white/60 font-light mb-10 fade-in" style="animation-delay: 0.4s">{{ i18n[locale].hero.subline }}</p>
      <a href="#portfolio" class="btn-primary text-lg fade-in" style="animation-delay: 0.6s">{{ i18n[locale].hero.cta }}</a>
    </div>
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </div>
  </section>

  <!-- Marquee -->
  <div class="py-6 border-y border-white/10 overflow-hidden">
    <div class="marquee-track flex whitespace-nowrap">
      {% for i in range(0, 3) %}
      <span class="marquee-segment flex whitespace-nowrap items-center">
        {% set words = ["ELAI STUDIO", "TECHNOLOGY", "AI", "DESIGN", "CREATIVITY", "DEVELOPMENT", "SOLUTION", "STRATEGY"] %}
        {% for word in words %}
        <span class="text-5xl md:text-7xl font-display font-light text-white/5 mx-6">{{ word }}</span>
        <span class="text-3xl md:text-4xl text-white/10 mx-6" style="-webkit-text-stroke: 1px rgba(255,255,255,0.15); color: transparent;">&#10022;</span>
        {% endfor %}
      </span>
      {% endfor %}
    </div>
  </div>

  <!-- About Section -->
  <section id="about" class="py-24 md:py-36">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-accent font-medium tracking-widest uppercase text-sm mb-4">{{ i18n[locale].about.title }}</p>
          <h2 class="section-title mb-8">{{ i18n[locale].about.title }}</h2>
          <p class="text-lg text-white/70 leading-relaxed">{{ i18n[locale].about.text }}</p>
        </div>
        <div class="grid grid-cols-3 gap-6">
          <div class="text-center">
            <div class="text-5xl font-display font-bold text-accent mb-2">20+</div>
            <p class="text-sm text-white/50">{{ i18n[locale].about.experience }}</p>
          </div>
          <div class="text-center">
            <div class="text-5xl font-display font-bold text-accent mb-2">120+</div>
            <p class="text-sm text-white/50">{{ i18n[locale].about.projects }}</p>
          </div>
          <div class="text-center">
            <div class="text-5xl font-display font-bold text-accent mb-2">80+</div>
            <p class="text-sm text-white/50">{{ i18n[locale].about.clients }}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-24 md:py-36 bg-white/[0.02]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-20">
        <p class="text-accent font-medium tracking-widest uppercase text-sm mb-4">{{ i18n[locale].services.subtitle }}</p>
        <h2 class="section-title">{{ i18n[locale].services.title }}</h2>
      </div>
      <div class="space-y-4">
        {% for service in i18n[locale].services.items %}
        <div class="service-card group flex flex-col md:flex-row md:items-center gap-6">
          <div class="flex items-center justify-center w-16 h-16 rounded-full bg-accent/10 text-accent font-display font-bold text-2xl shrink-0">
            0{{ loop.index }}
          </div>
          <div class="flex-1">
            <h3 class="text-2xl md:text-3xl font-display font-semibold mb-2 group-hover:text-accent transition-colors">{{ service.title }}</h3>
            <p class="text-white/50 leading-relaxed">{{ service.desc }}</p>
          </div>
          <svg class="w-8 h-8 text-white/20 group-hover:text-accent group-hover:translate-x-2 transition-all shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Portfolio Section -->
  <section id="portfolio" class="py-24 md:py-36">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16">
        <div>
          <p class="text-accent font-medium tracking-widest uppercase text-sm mb-4">{{ i18n[locale].portfolio.subtitle }}</p>
          <h2 class="section-title">{{ i18n[locale].portfolio.title }}</h2>
        </div>
        <a href="#" class="btn-outline mt-6 md:mt-0">{{ i18n[locale].portfolio.moreWorks }}</a>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {% set projects = [
          { "title": "Brand Identity Project", "cat": "Branding", "year": "2025" },
          { "title": "E-Commerce Platform", "cat": "Web Development", "year": "2025" },
          { "title": "Motion Reel", "cat": "Animation", "year": "2024" },
          { "title": "Corporate Website", "cat": "Web Design", "year": "2024" },
          { "title": "Product Commercial", "cat": "Film", "year": "2025" },
          { "title": "Startup Landing Page", "cat": "Web Development", "year": "2025" }
        ] %}
        {% for project in projects %}
        <div class="portfolio-card group {{ 'md:col-span-2' if loop.index == 1 }}">
          <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/20 to-transparent z-10"></div>
          <div class="absolute inset-0 bg-white/5 flex items-center justify-center">
            <span class="text-white/20 text-lg font-medium">{{ project.cat }} — Placeholder Image</span>
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-8 z-20">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs tracking-widest uppercase text-accent">{{ project.cat }}</span>
              <span class="text-xs text-white/30">{{ project.year }}</span>
            </div>
            <h3 class="text-2xl md:text-3xl font-display font-semibold group-hover:text-accent transition-colors">{{ project.title }}</h3>
          </div>
          <div class="absolute inset-0 z-30 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-dark/60">
            <span class="btn-primary">{{ i18n[locale].portfolio.viewProject }}</span>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section id="pricing" class="py-24 md:py-36 bg-white/[0.02]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-accent font-medium tracking-widest uppercase text-sm mb-4">{{ i18n[locale].pricing.subtitle }}</p>
        <h2 class="section-title">{{ i18n[locale].pricing.title }}</h2>
      </div>

      <!-- Slider container -->
      <div class="relative">
        <div class="overflow-hidden" id="pricing-viewport">
          <div class="flex transition-transform duration-500 ease-out" id="pricing-track">
            {% for pkg in i18n[locale].pricing.packages %}
            <div class="w-full md:w-1/2 lg:w-1/3 flex-shrink-0 px-3">
              <div class="relative border border-white/10 rounded-2xl p-8 h-full flex flex-col {{ 'border-accent/50 bg-accent/5' if pkg.popular }}">
                {% if pkg.popular %}
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-accent text-dark text-xs font-bold px-4 py-1 rounded-full uppercase tracking-wider">Popular</div>
                {% endif %}
                <h3 class="text-2xl font-display font-semibold mb-2">{{ pkg.name }}</h3>
                <div class="flex items-baseline gap-1 mb-4">
                  {% if pkg.type == 'custom' %}
                  <span class="text-4xl font-display font-bold text-accent">—</span>
                  {% elif pkg.type == 'starting' %}
                  <span class="text-sm text-white/50">{{ i18n[locale].pricing.startingFrom }}</span>
                  <span class="text-4xl font-display font-bold text-accent">{{ pkg.price }}</span>
                  {% else %}
                  <span class="text-4xl font-display font-bold text-accent">{{ pkg.price }}</span>
                  {% endif %}
                </div>
                {% if pkg.priceNote %}
                <p class="text-sm text-accent/70 -mt-2 mb-4">{{ pkg.priceNote }}</p>
                {% endif %}
                <p class="text-white/50 text-sm mb-6 leading-relaxed">{{ pkg.desc }}</p>
                <ul class="space-y-3 mb-8 flex-1">
                  {% for feature in pkg.features %}
                  <li class="flex items-start gap-3 text-sm text-white/70">
                    <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    {{ feature }}
                  </li>
                  {% endfor %}
                </ul>
                {% if pkg.type == 'custom' %}
                <a href="{{ '/' if locale == 'en' else '/' + locale + '/' }}quote/" class="btn-outline text-center justify-center">{{ i18n[locale].pricing.getQuote }}</a>
                {% else %}
                <a href="{{ '/' if locale == 'en' else '/' + locale + '/' }}quote/" class="btn-primary text-center justify-center">{{ i18n[locale].pricing.getQuote }}</a>
                {% endif %}
              </div>
            </div>
            {% endfor %}
          </div>
        </div>

        <!-- Slider arrows -->
        <button id="pricing-prev" class="absolute top-1/2 -translate-y-1/2 -left-4 md:-left-6 w-12 h-12 rounded-full border border-white/20 bg-dark/80 backdrop-blur flex items-center justify-center hover:border-accent transition-colors z-10">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="pricing-next" class="absolute top-1/2 -translate-y-1/2 -right-4 md:-right-6 w-12 h-12 rounded-full border border-white/20 bg-dark/80 backdrop-blur flex items-center justify-center hover:border-accent transition-colors z-10">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </button>

        <!-- Dots -->
        <div class="flex justify-center gap-2 mt-8" id="pricing-dots"></div>
      </div>
    </div>
  </section>

  <!-- Testimonials Marquee -->
  <div class="py-16 border-y border-white/10 overflow-hidden">
    <div class="marquee-track marquee-slow flex whitespace-nowrap">
      {% for i in range(0, 3) %}
      <span class="marquee-segment flex whitespace-nowrap">
        {% for item in i18n[locale].testimonials.items %}
        <span class="text-3xl md:text-5xl font-display font-light text-white/10 mx-8">★ {{ item }}</span>
        {% endfor %}
      </span>
      {% endfor %}
    </div>
  </div>

  <!-- Contact Section -->
  <section id="contact" class="py-24 md:py-36">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="text-accent font-medium tracking-widest uppercase text-sm mb-4">{{ i18n[locale].contact.cta }}</p>
      <h2 class="section-title mb-6">{{ i18n[locale].contact.title }}</h2>
      <p class="text-xl text-white/50 mb-12">{{ i18n[locale].contact.subtitle }}</p>
      <form class="max-w-2xl mx-auto space-y-6 text-left">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm text-white/50 mb-2">{{ i18n[locale].contact.nameLabel }}</label>
            <input type="text" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white placeholder-white/30 focus:border-accent focus:outline-none transition-colors" placeholder="{{ i18n[locale].contact.nameLabel }}">
          </div>
          <div>
            <label class="block text-sm text-white/50 mb-2">{{ i18n[locale].contact.emailLabel }}</label>
            <input type="email" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white placeholder-white/30 focus:border-accent focus:outline-none transition-colors" placeholder="{{ i18n[locale].contact.emailLabel }}">
          </div>
        </div>
        <div>
          <label class="block text-sm text-white/50 mb-2">{{ i18n[locale].contact.messageLabel }}</label>
          <textarea rows="5" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white placeholder-white/30 focus:border-accent focus:outline-none transition-colors resize-none" placeholder="{{ i18n[locale].contact.messageLabel }}"></textarea>
        </div>
        <div class="text-center pt-4">
          <button type="submit" class="btn-primary text-lg">{{ i18n[locale].contact.send }}</button>
        </div>
      </form>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-white/10 py-12">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-8">
        <div class="flex items-center gap-6">
          <img src="/assets/logo.svg" alt="ELAI" class="h-6 invert opacity-50">
          <span class="text-sm text-white/30">© 2025 {{ site.name }}. {{ i18n[locale].footer.rights }}</span>
        </div>
        <div class="flex items-center gap-8">
          <a href="#about" class="text-sm text-white/40 hover:text-white transition-colors">{{ i18n[locale].nav.about }}</a>
          <a href="#services" class="text-sm text-white/40 hover:text-white transition-colors">{{ i18n[locale].nav.services }}</a>
          <a href="#portfolio" class="text-sm text-white/40 hover:text-white transition-colors">{{ i18n[locale].nav.portfolio }}</a>
          <a href="#pricing" class="text-sm text-white/40 hover:text-white transition-colors">{{ i18n[locale].nav.pricing }}</a>
          <a href="#contact" class="text-sm text-white/40 hover:text-white transition-colors">{{ i18n[locale].nav.contact }}</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    // Navbar scroll effect
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar.style.background = 'rgba(10,10,10,0.7)';
        navbar.style.backdropFilter = 'blur(30px)';
        navbar.style.borderColor = 'rgba(255,255,255,0.12)';
      } else {
        navbar.style.background = 'rgba(255,255,255,0.05)';
        navbar.style.backdropFilter = 'blur(20px)';
        navbar.style.borderColor = 'rgba(255,255,255,0.08)';
      }
    });

    // Fullscreen mobile menu
    const menuToggle = document.getElementById('menu-toggle');
    const menuClose = document.getElementById('menu-close');
    const mobileMenu = document.getElementById('mobile-menu');
    function openMenu() {
      mobileMenu.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
    function closeMenu() {
      mobileMenu.classList.add('hidden');
      document.body.style.overflow = '';
    }
    menuToggle.addEventListener('click', openMenu);
    menuClose.addEventListener('click', closeMenu);
    mobileMenu.querySelectorAll('nav a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    // Pricing slider
    (function() {
      const track = document.getElementById('pricing-track');
      const viewport = document.getElementById('pricing-viewport');
      const prevBtn = document.getElementById('pricing-prev');
      const nextBtn = document.getElementById('pricing-next');
      const dotsContainer = document.getElementById('pricing-dots');
      if (!track) return;

      let current = 0;

      function getVisible() {
        const w = window.innerWidth;
        if (w >= 1024) return 3;
        if (w >= 768) return 2;
        return 1;
      }

      function getMaxSlide() {
        return Math.max(0, track.children.length - getVisible());
      }

      function updateSlider() {
        const cardWidth = 100 / getVisible();
        track.style.transform = 'translateX(-' + (current * cardWidth) + '%)';
        updateDots();
      }

      function updateDots() {
        const max = getMaxSlide();
        dotsContainer.innerHTML = '';
        for (let i = 0; i <= max; i++) {
          const dot = document.createElement('button');
          dot.className = 'w-2 h-2 rounded-full transition-colors ' + (i === current ? 'bg-accent' : 'bg-white/20');
          dot.addEventListener('click', () => { current = i; updateSlider(); });
          dotsContainer.appendChild(dot);
        }
      }

      prevBtn.addEventListener('click', () => {
        current = Math.max(0, current - 1);
        updateSlider();
      });

      nextBtn.addEventListener('click', () => {
        current = Math.min(getMaxSlide(), current + 1);
        updateSlider();
      });

      window.addEventListener('resize', () => {
        current = Math.min(current, getMaxSlide());
        updateSlider();
      });

      updateSlider();
    })();

    // Scroll animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('fade-in');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.service-card, .portfolio-card, #about, #contact').forEach(el => {
      observer.observe(el);
    });
  </script>
</body>
</html>
