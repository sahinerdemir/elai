<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ i18n[locale].portfolio.pageTitle }} — {{ site.name }}</title>
  <meta name="description" content="{{ i18n[locale].portfolio.pageDesc }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <meta property="og:title" content="{{ i18n[locale].portfolio.pageTitle }} — {{ site.name }}">
  <meta property="og:description" content="{{ i18n[locale].portfolio.pageDesc }}">
  <link rel="icon" type="image/png" href="/assets/favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body class="bg-dark text-white">

  <!-- Header -->
  <nav class="fixed z-50 transition-all duration-300" style="top: 32px; left: 32px; right: 32px; border-radius: 9999px; background: rgba(255,255,255,0.05); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.08);" id="navbar">
    <div class="px-6 py-3 flex items-center justify-between">
      <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}" class="flex items-center">
        <img src="/assets/logo.svg" alt="ELAI" class="invert" style="height: 26px;">
      </a>
      <div class="hidden md:flex items-center gap-10">
        <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}#about" class="nav-link">{{ i18n[locale].nav.about }}</a>
        <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}#services" class="nav-link">{{ i18n[locale].nav.services }}</a>
        <a href="{{ '/' if locale == 'en' else '/' + locale + '/' }}portfolio/" class="nav-link text-white">{{ i18n[locale].nav.portfolio }}</a>
        <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}#pricing" class="nav-link">{{ i18n[locale].nav.pricing }}</a>
        <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}#contact" class="nav-link">{{ i18n[locale].nav.contact }}</a>
      </div>
      <div class="flex items-center gap-6">
        <div class="lang-switcher flex gap-3">
          <a href="/portfolio/" class="{{ 'active' if lang == 'en' }}">EN</a>
          <a href="/es/portfolio/" class="{{ 'active' if lang == 'es' }}">ES</a>
          <a href="/ru/portfolio/" class="{{ 'active' if lang == 'ru' }}">RU</a>
        </div>
        <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}#contact" class="btn-primary text-sm hidden md:inline-flex">{{ i18n[locale].contact.cta }}</a>
        <button class="md:hidden text-white" id="menu-toggle" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
  </nav>

  <div class="fixed inset-0 z-[100] hidden md:hidden" id="mobile-menu">
    <div class="absolute inset-0" style="background: rgba(10,10,10,0.55); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);"></div>
    <div class="relative z-10 flex flex-col h-full px-8 py-10">
      <div class="flex items-center justify-between mb-16">
        <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}" class="flex items-center">
          <img src="/assets/logo.svg" alt="ELAI" class="invert" style="height: 26px;">
        </a>
        <button class="text-white w-10 h-10 flex items-center justify-center" id="menu-close" aria-label="Close">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <nav class="flex flex-col gap-8 flex-1">
        <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}#about" class="text-4xl font-display font-light text-white/80 hover:text-accent transition-colors">{{ i18n[locale].nav.about }}</a>
        <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}#services" class="text-4xl font-display font-light text-white/80 hover:text-accent transition-colors">{{ i18n[locale].nav.services }}</a>
        <a href="{{ '/' if locale == 'en' else '/' + locale + '/' }}portfolio/" class="text-4xl font-display font-light text-white/80 hover:text-accent transition-colors">{{ i18n[locale].nav.portfolio }}</a>
        <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}#pricing" class="text-4xl font-display font-light text-white/80 hover:text-accent transition-colors">{{ i18n[locale].nav.pricing }}</a>
        <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}#contact" class="text-4xl font-display font-light text-white/80 hover:text-accent transition-colors">{{ i18n[locale].nav.contact }}</a>
      </nav>
      <div class="pt-8 border-t border-white/10">
        <div class="lang-switcher flex gap-4">
          <a href="/portfolio/" class="text-sm {{ 'active' if lang == 'en' }}">EN</a>
          <a href="/es/portfolio/" class="text-sm {{ 'active' if lang == 'es' }}">ES</a>
          <a href="/ru/portfolio/" class="text-sm {{ 'active' if lang == 'ru' }}">RU</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Hero -->
  <section class="pt-40 pb-12 md:pt-48 md:pb-16">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-accent font-medium tracking-widest uppercase text-sm mb-4">{{ i18n[locale].portfolio.subtitle }}</p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold leading-tight mb-6">{{ i18n[locale].portfolio.pageTitle }}</h1>
      <p class="text-xl text-white/50 max-w-2xl">{{ i18n[locale].portfolio.pageDesc }}</p>
    </div>
  </section>

  <!-- Filter -->
  <section class="py-8 border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-wrap gap-3" id="portfolio-filters">
        <button class="filter-btn active" data-filter="all">{{ i18n[locale].portfolio.filterAll }}</button>
        <button class="filter-btn" data-filter="web">{{ i18n[locale].portfolio.filterWeb }}</button>
        <button class="filter-btn" data-filter="branding">{{ i18n[locale].portfolio.filterBranding }}</button>
        <button class="filter-btn" data-filter="animation">{{ i18n[locale].portfolio.filterAnimation }}</button>
        <button class="filter-btn" data-filter="film">{{ i18n[locale].portfolio.filterFilm }}</button>
      </div>
    </div>
  </section>

  <!-- Portfolio Grid -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="portfolio-grid">
        {% for project in portfolio.items %}
        {% set p = project[locale] %}
        <a href="{{ '/' if locale == 'en' else '/' + locale + '/' }}portfolio/{{ project.slug }}/" class="portfolio-item group no-underline block" data-category="{{ project.category }}">
          <div class="relative overflow-hidden rounded-2xl bg-white/5 cursor-pointer">
            <div class="aspect-[4/3] flex items-center justify-center">
              {% if project.thumbnail %}
              <img src="{{ project.thumbnail }}" alt="{{ p.title }}" class="w-full h-full object-cover" loading="lazy">
              {% else %}
              <span class="text-white/20 text-sm font-medium">{{ p.cat }} — Placeholder</span>
              {% endif %}
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-dark via-transparent to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-xs tracking-widest uppercase text-accent">{{ p.cat }}</span>
                <span class="text-xs text-white/30">{{ project.year }}</span>
              </div>
              <h3 class="text-xl font-display font-semibold group-hover:text-accent transition-colors">{{ p.title }}</h3>
            </div>
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-dark/60">
              <span class="btn-primary text-sm">{{ i18n[locale].portfolio.viewProject }}</span>
            </div>
          </div>
        </a>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Footer -->
  {% include "footer.njk" %}

  <script>
    // Navbar scroll
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar.style.background = 'rgba(10,10,10,0.7)';
        navbar.style.backdropFilter = 'blur(30px)';
        navbar.style.borderColor = 'rgba(255,255,255,0.12)';
      } else {
        navbar.style.background = 'rgba(255,255,255,0.05)';
        navbar.style.backdropFilter = 'blur(20px)';
        navbar.style.borderColor = 'rgba(255,255,255,0.08)';
      }
    });

    // Mobile menu
    const menuToggle = document.getElementById('menu-toggle');
    const menuClose = document.getElementById('menu-close');
    const mobileMenu = document.getElementById('mobile-menu');
    menuToggle.addEventListener('click', () => { mobileMenu.classList.remove('hidden'); document.body.style.overflow = 'hidden'; });
    menuClose.addEventListener('click', () => { mobileMenu.classList.add('hidden'); document.body.style.overflow = ''; });
    mobileMenu.querySelectorAll('nav a').forEach(link => { link.addEventListener('click', () => { mobileMenu.classList.add('hidden'); document.body.style.overflow = ''; }); });

    // Portfolio filter
    const filterBtns = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.portfolio-item');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.dataset.filter;
        items.forEach(item => {
          if (filter === 'all' || item.dataset.category === filter) {
            item.style.display = '';
          } else {
            item.style.display = 'none';
          }
        });
      });
    });
  </script>
</body>
</html>
