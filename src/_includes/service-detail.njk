<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ svc.metaTitle }}</title>
  <meta name="description" content="{{ svc.metaDesc }}">
  <meta name="keywords" content="{{ svc.keywords }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <meta property="og:title" content="{{ svc.metaTitle }}">
  <meta property="og:description" content="{{ svc.metaDesc }}">
  <meta property="og:image" content="{{ site.url }}{{ serviceData.image }}">
  <meta property="og:type" content="website">
  <link rel="icon" type="image/svg+xml" href="/assets/logo.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/style.css">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "{{ svc.title }}",
    "description": "{{ svc.metaDesc }}",
    "provider": {
      "@type": "Organization",
      "name": "{{ site.name }}",
      "url": "{{ site.url }}"
    }
  }
  </script>
</head>
<body class="bg-dark text-white">

  <!-- Header -->
  <nav class="fixed z-50 transition-all duration-300" style="top: 32px; left: 32px; right: 32px; border-radius: 9999px; background: rgba(255,255,255,0.05); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.08);" id="navbar">
    <div class="px-6 py-3 flex items-center justify-between">
      <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}" class="flex items-center">
        <img src="/assets/logo.svg" alt="ELAI" class="invert" style="height: 26px;">
      </a>
      <div class="hidden md:flex items-center gap-10">
        <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}#about" class="nav-link">{{ i18n[locale].nav.about }}</a>
        <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}#services" class="nav-link">{{ i18n[locale].nav.services }}</a>
        <a href="{{ '/' if locale == 'en' else '/' + locale + '/' }}portfolio/" class="nav-link">{{ i18n[locale].nav.portfolio }}</a>
        <a href="#pricing" class="nav-link">{{ i18n[locale].nav.pricing }}</a>
        <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}#contact" class="nav-link">{{ i18n[locale].nav.contact }}</a>
      </div>
      <div class="flex items-center gap-6">
        <div class="lang-switcher flex gap-3">
          <a href="/services/{{ serviceData.slug }}/" class="{{ 'active' if lang == 'en' }}">EN</a>
          <a href="/es/services/{{ serviceData.slug }}/" class="{{ 'active' if lang == 'es' }}">ES</a>
          <a href="/ru/services/{{ serviceData.slug }}/" class="{{ 'active' if lang == 'ru' }}">RU</a>
        </div>
        <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}#contact" class="btn-primary text-sm hidden md:inline-flex">{{ i18n[locale].contact.cta }}</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative pt-40 pb-24 md:pt-48 md:pb-32">
    <div class="absolute inset-0 z-0">
      <img src="{{ serviceData.image }}" alt="{{ svc.title }}" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-dark/30 to-dark"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <a href="{{ '/' if lang == 'en' else '/' + lang + '/' }}#services" class="inline-flex items-center gap-2 text-sm text-accent mb-8 hover:text-white transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        {{ i18n[locale].nav.services }}
      </a>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold leading-tight mb-6">{{ svc.title }}</h1>
      <p class="text-xl md:text-2xl text-white/60 font-light">{{ svc.heroSubtitle }}</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-6">
      <p class="text-xl md:text-2xl text-white/70 leading-relaxed font-light">{{ svc.intro }}</p>
    </div>
  </section>

  <!-- Content Sections -->
  {% for section in svc.sections %}
  <section class="py-12 md:py-16 {{ 'bg-white/[0.02]' if loop.index is odd }}">
    <div class="max-w-3xl mx-auto px-6">
      <div class="flex items-start gap-6">
        <span class="text-accent/30 font-display font-bold text-5xl leading-none shrink-0 hidden md:block">0{{ loop.index }}</span>
        <div>
          <h2 class="text-2xl md:text-3xl font-display font-semibold mb-4">{{ section.title }}</h2>
          <p class="text-lg text-white/60 leading-relaxed">{{ section.text }}</p>
        </div>
      </div>
    </div>
  </section>
  {% endfor %}

  <!-- Pricing Section -->
  <section id="pricing" class="py-24 md:py-36 bg-white/[0.02]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-accent font-medium tracking-widest uppercase text-sm mb-4">{{ i18n[locale].pricing.subtitle }}</p>
        <h2 class="section-title">{{ i18n[locale].pricing.title }}</h2>
      </div>
      <div class="relative">
        <div class="overflow-x-hidden overflow-y-visible" id="pricing-viewport">
          <div class="flex transition-transform duration-500 ease-out" id="pricing-track">
            {% for pkg in i18n[locale].pricing.packages %}
            <div class="w-full md:w-1/2 lg:w-1/3 flex-shrink-0 px-3 pt-4">
              <div class="relative overflow-visible border border-white/10 rounded-2xl p-8 h-full flex flex-col {{ 'border-accent/50 bg-accent/5' if pkg.popular }}">
                {% if pkg.popular %}
                <div class="absolute -top-3 right-6 bg-accent text-dark text-xs font-bold px-4 py-1 rounded-full uppercase tracking-wider pulse-badge">Popular</div>
                {% endif %}
                <h3 class="text-2xl font-display font-semibold mb-2">{{ pkg.name }}</h3>
                <div class="flex items-baseline gap-1 mb-4">
                  {% if pkg.type == 'custom' %}
                  <span class="text-4xl font-display font-bold text-accent">—</span>
                  {% elif pkg.type == 'starting' %}
                  <span class="text-sm text-white/50">{{ i18n[locale].pricing.startingFrom }}</span>
                  <span class="text-4xl font-display font-bold text-accent">{{ pkg.price }}</span>
                  {% else %}
                  <span class="text-4xl font-display font-bold text-accent">{{ pkg.price }}</span>
                  {% endif %}
                </div>
                {% if pkg.priceNote %}
                <p class="text-sm text-accent/70 -mt-2 mb-4">{{ pkg.priceNote }}</p>
                {% endif %}
                <p class="text-white/50 text-sm mb-6 leading-relaxed">{{ pkg.desc }}</p>
                <ul class="space-y-3 mb-8 flex-1">
                  {% for feature in pkg.features %}
                  <li class="flex items-start gap-3 text-sm text-white/70">
                    <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    {{ feature }}
                  </li>
                  {% endfor %}
                </ul>
                {% if pkg.type == 'custom' %}
                <button class="btn-outline text-center justify-center w-full quote-trigger" data-package="">{{ i18n[locale].pricing.requestQuote }}</button>
                {% else %}
                <button class="btn-primary text-center justify-center w-full quote-trigger" data-package="{{ pkg.name }}">{{ i18n[locale].pricing.getStarted }}</button>
                {% endif %}
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
        <button id="pricing-prev" class="absolute top-1/2 -translate-y-1/2 -left-4 md:-left-6 w-12 h-12 rounded-full border border-white/20 bg-dark/80 backdrop-blur flex items-center justify-center hover:border-accent transition-colors z-10">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="pricing-next" class="absolute top-1/2 -translate-y-1/2 -right-4 md:-right-6 w-12 h-12 rounded-full border border-white/20 bg-dark/80 backdrop-blur flex items-center justify-center hover:border-accent transition-colors z-10">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </button>
        <div class="flex justify-center gap-2 mt-8" id="pricing-dots"></div>
      </div>
    </div>
  </section>

  <!-- Quote Modal -->
  <div class="fixed inset-0 z-[200] hidden" id="quote-modal">
    <div class="absolute inset-0" style="background: rgba(10,10,10,0.55); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);"></div>
    <div class="relative z-10 h-full overflow-y-auto">
      <div class="min-h-full flex flex-col px-6 py-10">
        <div class="max-w-2xl mx-auto w-full flex justify-end mb-8">
          <button class="text-white/60 hover:text-white w-10 h-10 flex items-center justify-center transition-colors" id="quote-close" aria-label="Close">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div class="max-w-2xl mx-auto w-full flex-1">
          <div class="text-center mb-12">
            <h2 class="section-title mb-4" id="quote-title">{{ i18n[locale].quote.title }}</h2>
            <p class="text-lg text-white/50" id="quote-subtitle">{{ i18n[locale].quote.subtitle }}</p>
          </div>
          <div id="quote-package-badge" class="hidden mb-8">
            <div class="border border-accent/30 bg-accent/5 rounded-xl px-6 py-4 flex items-center gap-3">
              <span class="w-8 h-8 rounded-full bg-accent/20 flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </span>
              <div>
                <p class="text-xs text-white/40 uppercase tracking-wider">{{ i18n[locale].quote.selectedPackage }}</p>
                <p class="text-lg font-display font-semibold text-accent" id="quote-package-name"></p>
              </div>
            </div>
          </div>
          <form class="space-y-6">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm text-white/50 mb-2">{{ i18n[locale].quote.firstName }}</label>
                <input type="text" required class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white placeholder-white/30 focus:border-accent focus:outline-none transition-colors" placeholder="{{ i18n[locale].quote.firstName }}">
              </div>
              <div>
                <label class="block text-sm text-white/50 mb-2">{{ i18n[locale].quote.lastName }}</label>
                <input type="text" required class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white placeholder-white/30 focus:border-accent focus:outline-none transition-colors" placeholder="{{ i18n[locale].quote.lastName }}">
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm text-white/50 mb-2">{{ i18n[locale].quote.email }}</label>
                <input type="email" required class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white placeholder-white/30 focus:border-accent focus:outline-none transition-colors" placeholder="{{ i18n[locale].quote.email }}">
              </div>
              <div>
                <label class="block text-sm text-white/50 mb-2">{{ i18n[locale].quote.phone }}</label>
                <input type="tel" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white placeholder-white/30 focus:border-accent focus:outline-none transition-colors" placeholder="{{ i18n[locale].quote.phone }}">
              </div>
            </div>
            <div>
              <label class="block text-sm text-white/50 mb-2">{{ i18n[locale].quote.company }}</label>
              <input type="text" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white placeholder-white/30 focus:border-accent focus:outline-none transition-colors" placeholder="{{ i18n[locale].quote.company }}">
            </div>
            <div>
              <label class="block text-sm text-white/50 mb-2">{{ i18n[locale].quote.message }}</label>
              <textarea rows="4" required class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white placeholder-white/30 focus:border-accent focus:outline-none transition-colors resize-none" placeholder="{{ i18n[locale].quote.message }}"></textarea>
            </div>
            <div class="text-center pt-4 pb-10">
              <button type="submit" class="btn-primary text-lg">{{ i18n[locale].quote.send }}</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  {% include "footer.njk" %}

  <script>
    // Navbar scroll
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar.style.background = 'rgba(10,10,10,0.7)';
        navbar.style.backdropFilter = 'blur(30px)';
        navbar.style.borderColor = 'rgba(255,255,255,0.12)';
      } else {
        navbar.style.background = 'rgba(255,255,255,0.05)';
        navbar.style.backdropFilter = 'blur(20px)';
        navbar.style.borderColor = 'rgba(255,255,255,0.08)';
      }
    });

    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', (e) => {
        const target = document.querySelector(a.getAttribute('href'));
        if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth' }); }
      });
    });

    // Pricing slider
    (function() {
      const track = document.getElementById('pricing-track');
      const prevBtn = document.getElementById('pricing-prev');
      const nextBtn = document.getElementById('pricing-next');
      const dotsContainer = document.getElementById('pricing-dots');
      if (!track) return;
      let current = 0;
      function getVisible() { const w = window.innerWidth; if (w >= 1024) return 3; if (w >= 768) return 2; return 1; }
      function getMaxSlide() { return Math.max(0, track.children.length - getVisible()); }
      function updateSlider() { track.style.transform = 'translateX(-' + (current * (100 / getVisible())) + '%)'; updateDots(); }
      function updateDots() { const max = getMaxSlide(); dotsContainer.innerHTML = ''; for (let i = 0; i <= max; i++) { const d = document.createElement('button'); d.className = 'w-2 h-2 rounded-full transition-colors ' + (i === current ? 'bg-accent' : 'bg-white/20'); d.addEventListener('click', () => { current = i; updateSlider(); }); dotsContainer.appendChild(d); } }
      prevBtn.addEventListener('click', () => { current = Math.max(0, current - 1); updateSlider(); });
      nextBtn.addEventListener('click', () => { current = Math.min(getMaxSlide(), current + 1); updateSlider(); });
      window.addEventListener('resize', () => { current = Math.min(current, getMaxSlide()); updateSlider(); });
      updateSlider();
    })();

    // Quote modal
    const quoteModal = document.getElementById('quote-modal');
    const quoteClose = document.getElementById('quote-close');
    const quoteTitle = document.getElementById('quote-title');
    const quoteSubtitle = document.getElementById('quote-subtitle');
    const quoteBadge = document.getElementById('quote-package-badge');
    const quotePackageName = document.getElementById('quote-package-name');
    function openQuote(pkg) {
      if (pkg) {
        quoteTitle.textContent = '{{ i18n[locale].pricing.getStarted }}';
        quoteSubtitle.textContent = '{{ i18n[locale].quote.subtitlePackage }}';
        quoteBadge.classList.remove('hidden');
        quotePackageName.textContent = pkg;
      } else {
        quoteTitle.textContent = '{{ i18n[locale].quote.title }}';
        quoteSubtitle.textContent = '{{ i18n[locale].quote.subtitle }}';
        quoteBadge.classList.add('hidden');
      }
      quoteModal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
    function closeQuote() { quoteModal.classList.add('hidden'); document.body.style.overflow = ''; }
    quoteClose.addEventListener('click', closeQuote);
    document.querySelectorAll('.quote-trigger').forEach(btn => {
      btn.addEventListener('click', () => openQuote(btn.dataset.package));
    });
  </script>
</body>
</html>
